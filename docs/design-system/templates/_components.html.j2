  <line x1="60" y1="168" x2="276" y2="168" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="280" y="171" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">≥ 10 pt · minimumSelectionSize</text>
</svg>
{%- endmacro %}

{# --- Toolbar: cornerRadius + toolButtonSize + toolbarHeight + toolButtonGap.
      All four callouts use short cardinal paths, each landing in a distinct
      quadrant. -------------------------------------------------------- #}
{% macro illus_toolbar() -%}
<svg viewBox="0 0 520 260" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
