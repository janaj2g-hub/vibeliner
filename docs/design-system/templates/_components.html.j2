      is annotated in place with a small "min 3" label near the start of
      the stroke — not a dimension line. --------------------------------- #}
{% macro illus_freehand() -%}
<svg viewBox="0 0 480 220" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
  <!-- Freehand curve at 2.5 stroke -->
  <path d="M 50 130 Q 80 60 110 110 T 190 90 T 240 120"
        stroke="#EF4444" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  <!-- Sample dots at regular x-intervals along the curve (visual proxy for 3pt spacing) -->
  {% for i in range(13) %}
    {% set x = 50 + i * 16 %}
    {% set y = 130 - 30 * ((i % 5) / 4.0) %}
    <circle cx="{{ '%.2f' % x }}" cy="{{ '%.2f' % y }}" r="1.4" fill="currentColor" opacity="0.65"/>
  {% endfor %}
  <!-- Non-dimension annotation for min-points count: small label near curve start -->
  <line x1="50" y1="138" x2="50" y2="170" stroke="currentColor" stroke-width="0.5"/>
