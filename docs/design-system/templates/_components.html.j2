{# ======================================================== tool button #}
{#
  Tool icons adapted from Vibeliner/Editor/ToolbarIcons.swift, 15×15 viewBox.
  Stroke width 1.4 (pin ring) / 1.5 (others) — mirrors the runtime.
#}
{% macro tool_icon(tool) -%}
  <svg viewBox="0 0 15 15" width="16" height="16" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
  {%- if tool == 'pin' -%}
    <circle cx="7.5" cy="5" r="3.8" stroke-width="1.4"/>
    <line x1="7.5" y1="9" x2="7.5" y2="14" stroke-width="1.5"/>
  {%- elif tool == 'arrow' -%}
    <path d="M 2 13 L 13 2 M 8 2 L 13 2 L 13 7" stroke-width="1.4"/>
  {%- elif tool == 'line' -%}
    <path d="M 2 13 L 13 2" stroke-width="1.4"/>
  {%- elif tool == 'rectangle' -%}
    <rect x="1.25" y="1.25" width="12.5" height="12.5" rx="2" ry="2" stroke-width="1.5"/>
  {%- elif tool == 'circle' -%}
    <ellipse cx="7.5" cy="7.5" rx="6.25" ry="6.25" stroke-width="1.5"/>
  {%- elif tool == 'freehand' -%}
    <path d="M 1 7.5 Q 3 1 7.5 7.5 T 14 7.5" stroke-width="1.5"/>
  {%- elif tool == 'select' -%}
    <path d="M 3 2 L 12 7.5 L 8 8.5 L 10.5 13 L 9 13.8 L 6.5 9.3 L 3.5 12.3 Z" fill="currentColor" stroke-width="0.5"/>
  {%- endif -%}
  </svg>
{%- endmacro %}

{% macro tool_button(tool='pin', forced='') -%}
  <button type="button" class="ds-tool-btn{% if forced %} is-{{ forced }}{% endif %}" aria-label="{{ tool }}">
    {{ tool_icon(tool) }}
  </button>
{%- endmacro %}

{% macro tool_button_group() -%}
  <div class="ds-preview-states ds-preview-states--dark">
    <div class="ds-state-demo">
      <span class="ds-state-label">Default · all 7 tools</span>
      <div style="display: inline-flex; gap: 2px; padding: 4px; background: rgba(30,30,30,0.0); border-radius: 20px;">
      {% for t in ['select', 'pin', 'arrow', 'line', 'rectangle', 'circle', 'freehand'] %}
        {{ tool_button(t) }}
      {% endfor %}
      </div>
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover</span>
      {{ tool_button('pin', 'hover') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Active (selected tool)</span>
      {{ tool_button('arrow', 'active') }}
    </div>
  </div>
{%- endmacro %}

{# ========================================================= font sample #}
{% macro font_sample(name, token) -%}
  {%- set is_mono = 'monospaced' in (token.raw or '') -%}
  {%- set weight_num = {'ultralight': 100, 'thin': 200, 'light': 300, 'regular': 400, 'medium': 500, 'semibold': 600, 'bold': 700, 'heavy': 800, 'black': 900}.get(token.weight, 400) -%}
  <div class="ds-font-sample">
    <div class="ds-font-specimen" style="font-family: {{ 'ui-monospace, \"SF Mono\", Menlo, Consolas, monospace' if is_mono else '-apple-system, BlinkMacSystemFont, \"SF Pro Display\", \"Segoe UI\", sans-serif' }}; font-size: {{ token.size or 14 }}px; font-weight: {{ weight_num }};">{{ token | sample_text }}</div>
    <div class="ds-font-meta">
      <code>{{ name }}</code> — {{ 'monospace' if is_mono else 'system' }} · {{ token.size }}px · {{ token.weight }} ({{ weight_num }})
      {% if token.description %}<br><span style="text-transform: none; letter-spacing: 0;">{{ token.description }}</span>{% endif %}
    </div>
  </div>
{%- endmacro %}

{# ===================================================== dimension unit #}
{#
  Compute the display unit for a dimension token. YAML `unit_override` wins
  over the parser's mechanical unit (pt for CGFloat, int for Int). Int
  tokens get a blank label unless explicitly overridden — integer counts
  like `freehandMinPoints` read better with an explicit "points" suffix.
#}
{% macro dim_unit(token) -%}
  {%- if token.unit_override -%}{{ token.unit_override }}
  {%- elif token.unit == 'int' -%}
  {%- else -%}{{ token.unit }}{%- endif -%}
{%- endmacro %}

{# =================================================== dimension singleton #}
{% macro dimension_singleton(name, token) -%}
  <div class="ds-dim-card">
    <div>
      <div class="ds-dim-value">{{ token.value }}{%- set u = dim_unit(token) | trim -%}{%- if u %}<span class="ds-dim-unit">{{ u }}</span>{%- endif -%}</div>
    </div>
    <div>
      <div class="ds-dim-name">{{ name }}</div>
      {% if token.description %}<div class="ds-dim-desc">{{ token.description }}</div>{% endif %}
    </div>
  </div>
{%- endmacro %}

{# ==================================================== dimension group =====

  One full-width row per composition group. Left half: an illustration panel
  split dark/light (follows the page-level Both/Light/Dark toggle via
  .ds-illus-half--dark / .ds-illus-half--light classes — mirrors the swatch
  pattern). Right half: metadata panel with title, description, a two-col
  token list (name + value), and a "Used by" footer.

  The SVG illustrations below all draw at real scale inside a generous
  viewBox. Callouts use `currentColor` so the dark-half uses #888 and the
  light-half uses #666 via CSS, staying legible on each surface.
#}
{% macro dimension_group(gid, title, description, tokens, used_by) -%}
  <div class="ds-dim-group">
    <div class="ds-dim-illus-panel">
      <div class="ds-illus-half ds-illus-half--dark">{{ _illus(gid) }}</div>
      <div class="ds-illus-half ds-illus-half--light">{{ _illus(gid) }}</div>
    </div>
    <div class="ds-dim-meta">
      <h4 class="ds-dim-title">{{ title }}</h4>
      <p class="ds-dim-description">{{ description }}</p>
      <div class="ds-dim-tokens">
      {% for name, token in tokens %}
        <div class="ds-dim-token-row">
          <code>{{ name }}</code>
          <span class="ds-dim-token-value">{{ token.value }}{%- set u = dim_unit(token) | trim -%}{%- if u %}<span class="ds-dim-unit-inline"> {{ u }}</span>{%- endif -%}</span>
        </div>
      {% endfor %}
      </div>
      <div class="ds-dim-used-by">Used by: {{ used_by | join(', ') }}</div>
    </div>
  </div>
{%- endmacro %}

{# --- Illustration dispatcher ---------------------------------------------- #}
{% macro _illus(gid) -%}
  {%- if gid == 'badge' -%}{{ illus_badge() }}
  {%- elif gid == 'crosshair' -%}{{ illus_crosshair() }}
  {%- elif gid == 'arrow' -%}{{ illus_arrow() }}
  {%- elif gid == 'note-pill' -%}{{ illus_note_pill() }}
  {%- elif gid == 'dimension-label' -%}{{ illus_dimension_label() }}
  {%- elif gid == 'freehand' -%}{{ illus_freehand() }}
  {%- elif gid == 'shape-primitives' -%}{{ illus_shape_primitives() }}
  {%- elif gid == 'toolbar' -%}{{ illus_toolbar() }}
  {%- endif -%}
{%- endmacro %}

{# ---------------------------------------------------------------------------
   Callout drawing rules — applied to every illustration below:
     1. viewBox is wide enough to hold the longest label at 10px monospace
        (~6 SVG units per char). Default viewBox 0 0 480 220.
     2. Every leader line exits its shape at 0°, 90°, 180°, or 270°. If a
        callout can't land in one cardinal pass, it elbows 90° — never
        diagonal.
     3. Labels are placed in distinct quadrants with ≥ 20 SVG-unit vertical
        separation on the same side. Shared layout: shape centered around
        x=110 y=110; labels land in a column at x=260+, stacked at y=50 /
        y=85 / y=130 / y=175 as needed.
     4. Non-spatial tokens (opacity, min-counts) are NOT drawn with
        dimension lines. Opacity reads visually from the shape's actual
        transparency; counts live in the sidebar token list.
     5. Dimension-callout style: stroke-width 0.5, dash "2 2", 4-unit
        perpendicular ticks at segment ends. Labels at 10px monospace with
        a 4-unit gap from the leader terminus.
  --------------------------------------------------------------------------- #}

{# --- Badge: leader-only labels for diameter and font-size. The badge is
      a small shape — a dimension bracket adds scaffolding that the shape
      can't really host. Clean leaders read better. #}
{% macro illus_badge() -%}
<svg viewBox="0 0 480 220" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
  <!-- Badge enlarged for illustrative presence; glyph scaled to match. -->
  <circle cx="120" cy="110" r="38" fill="#EF4444"/>
  <text x="120" y="125" font-family="-apple-system, sans-serif" font-size="38" font-weight="600" fill="white" text-anchor="middle">1</text>
  <!-- Label 1 — badgeDiameter. Leader exits the badge's right edge and
       runs straight to the label column. -->
  <line x1="158" y1="90" x2="256" y2="90" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="93" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">18 pt · badgeDiameter</text>
  <!-- Label 2 — badgeFont. Leader exits the bottom of the badge, elbows
       RIGHT to the label column. -->
  <line x1="120" y1="148" x2="120" y2="170" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="120" y1="170" x2="256" y2="170" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="173" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">9 pt semibold · badgeFont</text>
</svg>
{%- endmacro %}

{# --- Crosshair: real-scale ("actual size") reference on the left + a 4×
      zoomed version on the right with leader-only labels. The real shape
      is 2.3pt × 20pt — too small for dimension-line grammar (brackets +
      ticks would crowd into a few pixels), so the zoomed version hosts
      the labels and the real-scale one anchors truth.
      Opacity stays sidebar-only (visible via the shape's 0.85 alpha). #}
{% macro illus_crosshair() -%}
<svg viewBox="0 0 480 220" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
  <!-- Real-scale crosshair: the honest view of what the user actually sees. -->
  <g opacity="0.85" stroke="#AFA9EC" stroke-width="2.3" stroke-linecap="round">
    <line x1="70" y1="100" x2="70" y2="120"/>
    <line x1="60" y1="110" x2="80" y2="110"/>
  </g>
  <text x="70" y="142" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" opacity="0.55" text-anchor="middle">actual size</text>
  <!-- Scale bridge between the real and zoomed views -->
  <line x1="98" y1="110" x2="148" y2="110" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="123" y="103" font-family="ui-monospace, monospace" font-size="9" fill="currentColor" opacity="0.7" text-anchor="middle">shown 4×</text>
  <!-- Zoomed crosshair: 4× scale so labels have breathing room. -->
  <g opacity="0.85" stroke="#AFA9EC" stroke-width="9.2" stroke-linecap="round">
    <line x1="200" y1="70" x2="200" y2="150"/>
    <line x1="160" y1="110" x2="240" y2="110"/>
  </g>
  <!-- Label 1 — thickness. Leader starts at the top-right edge of the
       vertical arm, exits UP then elbows RIGHT to the label column. -->
  <line x1="205" y1="66" x2="205" y2="50" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="205" y1="50" x2="256" y2="50" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="53" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">2.3 pt · crosshairThickness</text>
  <!-- Label 2 — tick length. Leader starts at the right end of the
       horizontal arm and goes RIGHT. Single segment, no elbow. -->
  <line x1="245" y1="110" x2="256" y2="110" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="113" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">10 pt · crosshairTickLength (arm length)</text>
</svg>
{%- endmacro %}

{# --- Arrow: open chevron (two separate stroked arms). Shaft strokeWidth,
      chevronLength, and chevronAngle (as an arc — no dim line).
      Shaft runs from (60, 180) to (200, 60). Chevron arms are each 12
      units long, splayed ±28° off the shaft's back-pointing direction
      — matches the Swift arrowChevronAngle semantic ("28° off each arm
      from shaft"), giving a visible V. Arc annotation sweeps between
      the two arms at the tip. #}
{% macro illus_arrow() -%}
<svg viewBox="0 0 480 240" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
  <g stroke="#EF4444" stroke-width="2.5" stroke-linecap="round" fill="none">
    <!-- Main shaft -->
    <line x1="60" y1="180" x2="200" y2="60"/>
    <!-- Chevron arm 1 (rotated +28° from shaft-back direction): tip to (188.3, 62.5) -->
    <line x1="200" y1="60" x2="188.3" y2="62.5"/>
    <!-- Chevron arm 2 (rotated -28°): tip to (195.5, 71.1) -->
    <line x1="200" y1="60" x2="195.5" y2="71.1"/>
  </g>
  <!-- Callout 1 — strokeWidth (2.5 pt). Leader UP from a point just above
       the shaft near its midpoint, then RIGHT to the label column. -->
  <line x1="130" y1="123" x2="130" y2="100" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="130" y1="100" x2="256" y2="100" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="103" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">2.5 pt · strokeWidth (shared)</text>
  <!-- Callout 2 — arrowChevronLength (12 pt). Dim line along arm 1,
       projected to horizontal for a cardinal read. Arm 1 end is at (188.3, 62.5);
       tip is (200, 60). Leader exits UP from the mid-arm, elbow RIGHT. -->
  <line x1="194.2" y1="61.3" x2="194.2" y2="40" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="194.2" y1="40" x2="256" y2="40" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="260" y="43" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">12 pt · arrowChevronLength</text>
  <!-- Callout 3 — arrowChevronAngle (28°). Arc between the two chevron
       arms at the tip. The label sits adjacent to the arc; no dashed leader. -->
  <path d="M 192.6 62.0 A 9 9 0 0 1 197.1 68.4" fill="none" stroke="currentColor" stroke-width="0.5"/>
  <text x="210" y="78" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">28° · arrowChevronAngle</text>
</svg>
{%- endmacro %}

