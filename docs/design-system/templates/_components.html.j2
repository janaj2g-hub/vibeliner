  <rect x="40" y="120" width="220" height="40" rx="20" ry="20"
        fill="rgba(30,30,30,0.92)" stroke="rgba(255,255,255,0.12)" stroke-width="0.8"/>
  <!-- Six tool buttons (30pt diameter, 2pt gap). Middle one highlighted. -->
  {% for i in range(6) %}
    {% set cx = 62 + i * 32 %}
    <circle cx="{{ cx }}" cy="140" r="15" fill="{{ 'rgba(175,169,236,0.2)' if i == 2 else 'transparent' }}"/>
  {% endfor %}
  <!-- Callout 1 — toolbarCornerRadius (20 pt). Short leader UP from the
       top-left corner, then RIGHT a little, then to the label column. -->
  <line x1="60" y1="120" x2="60" y2="88" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="60" y1="88" x2="296" y2="88" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="300" y="91" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">20 pt · toolbarCornerRadius</text>
  <!-- Callout 2 — toolButtonSize (30 pt). Short UP from the first button's top,
       then RIGHT. No big horizontal hop across the illustration. -->
  <line x1="47" y1="125" x2="47" y2="108" stroke="currentColor" stroke-width="0.5"/>
  <line x1="77" y1="125" x2="77" y2="108" stroke="currentColor" stroke-width="0.5"/>
  <line x1="47" y1="112" x2="77" y2="112" stroke="currentColor" stroke-width="0.5"/>
  <line x1="47" y1="108" x2="47" y2="116" stroke="currentColor" stroke-width="0.5"/>
  <line x1="77" y1="108" x2="77" y2="116" stroke="currentColor" stroke-width="0.5"/>
  <line x1="77" y1="112" x2="296" y2="112" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="300" y="115" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">30 pt · toolButtonSize</text>
  <!-- Callout 3 — toolbarHeight (40 pt). Compact right-side bracket, ticks
       touching the pill edges, very short dashed leader to label. -->
  <line x1="268" y1="120" x2="268" y2="160" stroke="currentColor" stroke-width="0.5"/>
  <line x1="264" y1="120" x2="272" y2="120" stroke="currentColor" stroke-width="0.5"/>
  <line x1="264" y1="160" x2="272" y2="160" stroke="currentColor" stroke-width="0.5"/>
  <line x1="272" y1="140" x2="296" y2="140" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="300" y="143" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">40 pt · toolbarHeight</text>
  <!-- Callout 4 — toolButtonGap (2 pt). Dim line between first two buttons;
