{#
  Component macros for the Vibeliner design system HTML.
  Imported as `c` by design-system.html.j2.

  These macros rely on CSS classes defined in the main template — do NOT
  duplicate CSS here. Every macro produces visually complete output and
  relies on real CSS :hover states (no fake "hover variant" cards).
#}

{# ============================================================ swatch

  Fixed-height swatch card with five regions:

    1. Title (44px) — centered monospace token name, divider below.
    2. Preview (64px) — split 50/50. Left half: dark surface #1e1e1e with
       the token's dark value on top. Right half: light surface #f5f5f7
       with the light value on top. Static tokens use the same color on
       both halves. Alias tokens show "→ targetToken" spanning the row.
       Text tokens in the pill-button family render a real "Copy Prompt"
       mini pill using the surrounding bg/border tokens plus the token's
       own color as text.
    3. Value (56px) — DARK / LIGHT labels + rgba strings in matching
       halves. Static tokens: single full-width STATIC cell. Alias: ALIAS
       cell with target name. Divider below.
    4. Used-by footer (flex: 1) — "Used by:" label on its own line, file
       list wrapping inline; a small JS pass at the bottom of the page
       appends "+N more" only when the available height overflows.

  The card has a fixed minimum height; the page-level Both/Light/Dark
  swatch toggle uses CSS to hide/show halves without reflowing the card.
#}
{%- set _text_pill_tokens = {
  'pillButtonText': ('pillButtonBg', 'pillButtonBorder'),
  'pillButtonHoverText': ('pillButtonHoverBg', 'pillButtonHoverBorder'),
  'pillButtonPrimaryText': ('pillButtonPrimaryBg', 'pillButtonPrimaryBorder'),
} -%}

{% macro _text_pill_halves(token, bg_name, border_name) -%}
  {%- set bg = all_tokens.get(bg_name) if all_tokens else None -%}
  {%- set border = all_tokens.get(border_name) if all_tokens else None -%}
  {%- set bg_dark = (bg.dark | resolve_rgba) if bg else '' -%}
  {%- set bg_light = (bg.light | resolve_rgba) if bg else '' -%}
  {%- set br_dark = (border.dark | resolve_rgba) if border else '' -%}
  {%- set br_light = (border.light | resolve_rgba) if border else '' -%}
  {%- set tx_dark = token.dark | resolve_rgba -%}
  {%- set tx_light = token.light | resolve_rgba -%}
  <div class="ds-swatch-half ds-swatch-half--dark">
    <div class="ds-text-pill" style="background: {{ bg_dark or 'transparent' }}; border-color: {{ br_dark or 'transparent' }}; color: {{ tx_dark or 'inherit' }};">Copy Prompt</div>
  </div>
  <div class="ds-swatch-half ds-swatch-half--light">
    <div class="ds-text-pill" style="background: {{ bg_light or 'transparent' }}; border-color: {{ br_light or 'transparent' }}; color: {{ tx_light or 'inherit' }};">Copy Prompt</div>
  </div>
{%- endmacro %}

{% macro _usage_footer(files) -%}
  <div class="ds-swatch-usage">
    <div class="ds-swatch-usage-label">Used by:</div>
    {% if files %}
      <div class="ds-swatch-usage-list" data-total="{{ files | length }}" title="{{ files | join(', ') }}">
      {%- for f in files -%}<span class="ds-swatch-file">{{ f }}</span>{%- endfor -%}
      </div>
    {% else %}
      <div class="ds-swatch-usage-list ds-swatch-usage-empty">(none)</div>
    {% endif %}
  </div>
{%- endmacro %}

{% macro swatch(name, token, mode=None) -%}
  {%- set is_alias = token.kind == 'alias' -%}
  {%- set is_dynamic = token.kind == 'dynamic' -%}
  {%- set pill_pair = _text_pill_tokens.get(name) -%}
  <div class="ds-swatch{% if is_alias %} ds-swatch--alias{% endif %}">
    <div class="ds-swatch-title">{{ name }}</div>

    {# --- Preview row (64px) --- #}
    {% if is_alias %}
      <div class="ds-swatch-preview ds-swatch-preview--alias">
        <div class="ds-swatch-alias-target">→ <code>{{ token.target or '?' }}</code></div>
      </div>
    {% elif pill_pair %}
      <div class="ds-swatch-preview">
        {{ _text_pill_halves(token, pill_pair[0], pill_pair[1]) }}
      </div>
    {% elif is_dynamic %}
      {%- set d_rgba = (token.dark | resolve_rgba) or 'transparent' -%}
      {%- set l_rgba = (token.light | resolve_rgba) or 'transparent' -%}
      <div class="ds-swatch-preview">
        <div class="ds-swatch-half ds-swatch-half--dark"><div class="ds-swatch-fill" style="background: {{ d_rgba }};"></div></div>
        <div class="ds-swatch-half ds-swatch-half--light"><div class="ds-swatch-fill" style="background: {{ l_rgba }};"></div></div>
      </div>
    {% else %}
      {%- set fill = token.rgba or token.raw -%}
      <div class="ds-swatch-preview">
        <div class="ds-swatch-half ds-swatch-half--dark"><div class="ds-swatch-fill" style="background: {{ fill }};"></div></div>
        <div class="ds-swatch-half ds-swatch-half--light"><div class="ds-swatch-fill" style="background: {{ fill }};"></div></div>
      </div>
    {% endif %}

    {# --- Value row (56px) --- #}
    {% if is_alias %}
      <div class="ds-swatch-values ds-swatch-values--single">
        <span class="ds-swatch-label">Alias</span>
        <code>{{ token.target or '?' }}</code>
      </div>
    {% elif is_dynamic %}
      {%- set d_val = (token.dark | resolve_rgba) or '—' -%}
      {%- set l_val = (token.light | resolve_rgba) or '—' -%}
      <div class="ds-swatch-values">
        <div class="ds-swatch-value-half ds-swatch-value-half--dark">
          <span class="ds-swatch-label">Dark</span>
          <code>{{ d_val }}</code>
        </div>
        <div class="ds-swatch-value-half ds-swatch-value-half--light">
          <span class="ds-swatch-label">Light</span>
          <code>{{ l_val }}</code>
        </div>
      </div>
    {% else %}
      <div class="ds-swatch-values ds-swatch-values--single">
        <span class="ds-swatch-label">Static</span>
        <code>{% if token.hex %}{{ token.hex }} · {% endif %}{{ token.rgba or token.raw }}</code>
      </div>
    {% endif %}

    {# --- Used-by footer --- #}
    {{ _usage_footer(token.consumed_by) }}
  </div>
{%- endmacro %}

{# ==================================================== consumed_by line #}
{% macro consumed_by(files, truncate=3) -%}
  Used by: {% if not files -%}
    <em>(none)</em>
  {%- else -%}
    <span title="{{ files | join(', ') }}">{{ files | truncate_list(truncate) }}</span>
  {%- endif -%}
{%- endmacro %}

{# ==================================================== pill button base #}
{% macro pill_button(label='Copy Prompt', variant='default', forced='') -%}
  <button type="button" class="ds-pill-btn ds-pill-btn--{{ variant }}{% if forced %} is-{{ forced }}{% endif %}">{{ label }}</button>
{%- endmacro %}

{% macro pill_button_group() -%}
  <div class="ds-preview-states">
    <div class="ds-state-demo">
      <span class="ds-state-label">Default</span>
      {{ pill_button('Copy Prompt', 'default') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover</span>
      {{ pill_button('Copy Prompt', 'default', 'hover') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Active</span>
      {{ pill_button('Copy Prompt', 'default', 'active') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Copied</span>
      {{ pill_button('Copied ✓', 'copied') }}
    </div>
  </div>
{%- endmacro %}

{% macro pill_button_primary(label='Next', forced='') -%}
  <button type="button" class="ds-pill-btn ds-pill-btn--primary{% if forced %} is-{{ forced }}{% endif %}">{{ label }}</button>
{%- endmacro %}

{% macro pill_button_primary_group() -%}
  <div class="ds-preview-states">
    <div class="ds-state-demo">
      <span class="ds-state-label">Default</span>
      {{ pill_button_primary('Get started') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover</span>
      {{ pill_button_primary('Get started', 'hover') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Active</span>
      {{ pill_button_primary('Get started', 'active') }}
    </div>
  </div>
{%- endmacro %}

{# ==================================================== secondary button #}
{% macro secondary_button(label='+ Add image', forced='') -%}
  <button type="button" class="ds-secondary-btn{% if forced %} is-{{ forced }}{% endif %}">{{ label }}</button>
{%- endmacro %}

{% macro secondary_button_group() -%}
  <div class="ds-preview-states">
    <div class="ds-state-demo">
      <span class="ds-state-label">Default</span>
      {{ secondary_button('+ Add image') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover</span>
      {{ secondary_button('+ Add image', 'hover') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Active</span>
      {{ secondary_button('+ Add image', 'active') }}
    </div>
  </div>
{%- endmacro %}

{# =================================================== segmented control #}
{% macro segmented_control(items=['IDE', 'App'], active=0, variant='default') -%}
  <div class="ds-segmented ds-segmented--{{ variant }}" role="group">
    {% for item in items %}
      <button type="button" class="ds-segmented-item{% if loop.index0 == active %} active{% endif %}">{{ item }}</button>
    {% endfor %}
  </div>
{%- endmacro %}

{% macro segmented_control_group() -%}
  <div class="ds-preview-stack">
    <div class="ds-state-demo">
      <span class="ds-state-label">Toolbar variant · IDE selected</span>
      {{ segmented_control(items=['IDE', 'App'], active=0, variant='default') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Settings variant · Preamble selected</span>
      {{ segmented_control(items=['Preamble', 'Tools', 'Footer', 'Multi-image'], active=0, variant='primary') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover + active states (forced) on inactive items</span>
      <div class="ds-segmented ds-segmented--default" role="group">
        <button type="button" class="ds-segmented-item">Default</button>
        <button type="button" class="ds-segmented-item is-hover">Hover</button>
        <button type="button" class="ds-segmented-item is-active">Active</button>
        <button type="button" class="ds-segmented-item active">Selected</button>
      </div>
    </div>
  </div>
{%- endmacro %}

{# ========================================================== note pill #}
{% macro note_pill(text='Fix this padding', state='default') -%}
  <span class="ds-note-pill ds-note-pill--{{ state }}">{{ text }}</span>
{%- endmacro %}

{% macro note_pill_group() -%}
  <div class="ds-preview-states">
    <div class="ds-state-demo">
      <span class="ds-state-label">Default</span>
      {{ note_pill('Fix padding', 'default') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Hover</span>
      {{ note_pill('Fix padding', 'hover') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Selected</span>
      {{ note_pill('Fix padding', 'selected') }}
    </div>
    <div class="ds-state-demo">
      <span class="ds-state-label">Editing</span>
      {{ note_pill('Fix padding', 'editing') }}
