{# =================================================== composed surfaces #}
{#
  For the Surfaces section we dispatch a family-specific mini composition
  when we have one; otherwise fall back to a dual-bar swatch.
#}
{% macro surface_sample(name, token) -%}
  {%- set fam = token.family -%}
  {%- if fam == 'toolbar' and name == 'toolbarBg' -%}
    {{ surface_toolbar() }}
  {%- elif fam == 'status-pill' and name == 'statusPillBg' -%}
    {{ surface_status_pill() }}
  {%- elif fam == 'settings-field' and name == 'settingsFieldSurface' -%}
    {{ surface_settings_field() }}
  {%- elif fam == 'settings-field' and name == 'settingsFrameSurface' -%}
    {{ surface_settings_frame() }}
  {%- elif fam == 'settings-field' and name == 'settingsPreviewSurface' -%}
    {{ surface_preview() }}
  {%- elif fam == 'setup-window' and name == 'setupFieldBg' -%}
    {{ surface_setup_field() }}
  {%- else -%}
    {{ swatch(name, token, mode='dual') }}
  {%- endif -%}
{%- endmacro %}

{% macro surface_toolbar() -%}
  <div class="ds-surface-demo ds-surface-demo--toolbar">
    <div class="ds-mini-toolbar">
      {{ tool_button('select', 'default') }}
      {{ tool_button('pin', 'default') }}
      {{ tool_button('arrow', 'default') }}
      <span class="ds-mini-divider"></span>
      {{ pill_button('Copy Prompt') }}
    </div>
    <div class="ds-surface-caption"><code>toolbarBg</code> · floating editor toolbar</div>
  </div>
{%- endmacro %}

{% macro surface_status_pill() -%}
  <div class="ds-surface-demo ds-surface-demo--screenshot">
    {{ status_pill('3 notes · 1024×768', 'dark') }}
    <div class="ds-surface-caption"><code>statusPillBg</code> · under the editor</div>
  </div>
{%- endmacro %}

{% macro surface_settings_field() -%}
  <div class="ds-surface-demo">
    <div class="ds-mini-field">
      <code>/Users/jon/captures</code>
      {{ pill_button('Change') }}
    </div>
    <div class="ds-surface-caption"><code>settingsFieldSurface</code> · path field in General</div>
  </div>
{%- endmacro %}

{% macro surface_settings_frame() -%}
  <div class="ds-surface-demo">
    <div class="ds-mini-frame">
      <div class="ds-mini-frame-title">Hotkey</div>
      <div class="ds-mini-frame-body">⌘ ⇧ 6 — Capture</div>
    </div>
    <div class="ds-surface-caption"><code>settingsFrameSurface</code> · framed sections</div>
  </div>
{%- endmacro %}

{% macro surface_preview() -%}
  <div class="ds-surface-demo">
    <div class="ds-mini-preview"><code>&gt; A note I wrote about padding.</code></div>
    <div class="ds-surface-caption"><code>settingsPreviewSurface</code> · prompt preview</div>
  </div>
{%- endmacro %}

{% macro surface_setup_field() -%}
  <div class="ds-surface-demo">
    <div class="ds-mini-kbd-row">
      <kbd>⌘</kbd><kbd>⇧</kbd><kbd>6</kbd>
    </div>
    <div class="ds-surface-caption"><code>setupFieldBg</code> · shortcut display</div>
  </div>
{%- endmacro %}
