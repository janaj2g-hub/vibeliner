{# --- Freehand: strokeWidth + sampleInterval (horizontal dim between two
      adjacent dots on a flat stretch of the curve) + minPoints (a small
      "min 3" bracket tethered to the first three dots — no abstract ticks). #}
{% macro illus_freehand() -%}
<svg viewBox="0 0 480 220" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
  <!-- Freehand curve at 2.5 stroke. Sample dots are placed explicitly at
       known positions so the callouts attach to real coordinates. -->
  {# Curve chosen to give a flat stretch in the middle (dots 4,5) and a
     rolling start (dots 0,1,2). #}
  <path d="M 60 100 C 110 60, 160 60, 200 80 S 260 120, 300 100"
        stroke="#EF4444" stroke-width="2.5" fill="none" stroke-linecap="round"/>
  {# Sample dots — deliberate positions, approximating an evenly-sampled curve. #}
  {% set dots = [(60, 100), (82, 78), (108, 66), (140, 64), (170, 70), (200, 80), (232, 96), (260, 108), (288, 106)] %}
  {% for x, y in dots %}
    <circle cx="{{ x }}" cy="{{ y }}" r="1.6" fill="currentColor" opacity="0.7"/>
  {% endfor %}
  <!-- Callout 1 — strokeWidth (2.5 pt, shared). Leader from a point just above
       the curve midpoint UP then RIGHT. -->
  <line x1="200" y1="70" x2="200" y2="40" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="200" y1="40" x2="316" y2="40" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="320" y="43" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">2.5 pt · strokeWidth (shared)</text>
  <!-- Callout 2 — freehandSampleInterval (3 pt). Horizontal dim line between
       dots 3 (140, 64) and 4 (170, 70) — the flatter upper stretch. Placed
       ABOVE the curve so it reads without overlapping the curve itself. -->
  <line x1="140" y1="60" x2="140" y2="44" stroke="currentColor" stroke-width="0.5"/>
  <line x1="170" y1="66" x2="170" y2="44" stroke="currentColor" stroke-width="0.5"/>
  <line x1="140" y1="48" x2="170" y2="48" stroke="currentColor" stroke-width="0.5"/>
  <line x1="140" y1="44" x2="140" y2="52" stroke="currentColor" stroke-width="0.5"/>
  <line x1="170" y1="44" x2="170" y2="52" stroke="currentColor" stroke-width="0.5"/>
  <line x1="170" y1="48" x2="200" y2="48" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <line x1="200" y1="48" x2="200" y2="70" stroke="currentColor" stroke-width="0.5" stroke-dasharray="2 2"/>
  <text x="172" y="38" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">3 pt · sampleInterval</text>
  <!-- Callout 3 — freehandMinPoints. Bracket spans EXACTLY the first three
       sample dots: from dot 0 (x=60) to dot 2 (x=108), sitting below the
       curve. Short "min 3" label underneath. No dimension-line ticks — it's
       a spanning bracket, not a measured length. -->
  <line x1="60"  y1="108" x2="60"  y2="150" stroke="currentColor" stroke-width="0.5"/>
  <line x1="108" y1="74"  x2="108" y2="150" stroke="currentColor" stroke-width="0.5"/>
  <line x1="60"  y1="150" x2="108" y2="150" stroke="currentColor" stroke-width="0.5"/>
  <text x="62" y="165" font-family="ui-monospace, monospace" font-size="10" fill="currentColor">min 3 · freehandMinPoints</text>
</svg>
{%- endmacro %}

{# --- Shape primitives: strokeWidth + rectCornerRadius + minimumSelectionSize #}
{% macro illus_shape_primitives() -%}
<svg viewBox="0 0 480 240" width="100%" preserveAspectRatio="xMidYMid meet" class="ds-illus-svg">
