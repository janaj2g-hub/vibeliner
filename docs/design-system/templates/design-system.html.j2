{% import "_components.html.j2" as c with context %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Vibeliner Design System</title>
<style>
/* ==========================================================================
   Vibeliner Design System — doc chrome
   Chrome intentionally uses Vibeliner's own tokens where practical.
   ========================================================================== */

/* --- Tokens: doc theme (light default, dark via body.dark / system media) - */
:root {
  /* Typography */
  --ds-system: -apple-system, BlinkMacSystemFont, "SF Pro Display", "Segoe UI", Roboto, sans-serif;
  --ds-mono: ui-monospace, "SF Mono", Menlo, Monaco, Consolas, monospace;

  /* Surfaces (light default) */
  --ds-bg: #fafbfc;
  --ds-bg-muted: #f2f3f5;
  --ds-surface: #ffffff;
  --ds-surface-hover: #f6f7f9;
  --ds-border: rgba(15, 23, 42, 0.10);
  --ds-border-strong: rgba(15, 23, 42, 0.18);
  --ds-divider: rgba(15, 23, 42, 0.08);

  /* Foreground */
  --ds-fg: #0f172a;
  --ds-fg-muted: rgba(15, 23, 42, 0.64);
  --ds-fg-dim: rgba(15, 23, 42, 0.42);

  /* Brand — Vibeliner purple */
  --ds-accent: #534AB7;                 /* purpleDark */
  --ds-accent-soft: rgba(83, 74, 183, 0.08);
  --ds-accent-strong: rgba(83, 74, 183, 0.22);

  /* Chrome tokens (mirroring Vibeliner runtime) */
  --ds-chrome-border: rgba(175, 169, 236, 0.22);
  --ds-pill-border: rgba(83, 74, 183, 0.42);
  --ds-pill-bg: rgba(83, 74, 183, 0.08);
  --ds-pill-text: #534AB7;

  /* Swatch reference backgrounds (single bar split dark/light) */
  --ds-bar-dark: #1e1e1e;               /* toolbarBg dark */
  --ds-bar-light: #f5f5f7;              /* toolbarBg light (approx) */
}

/* Dark mode — explicit override via body.dark */
body.dark {
  --ds-bg: #0b0d12;
  --ds-bg-muted: #12141b;
  --ds-surface: #15181f;
  --ds-surface-hover: #1a1e27;
  --ds-border: rgba(255, 255, 255, 0.08);
  --ds-border-strong: rgba(255, 255, 255, 0.16);
  --ds-divider: rgba(255, 255, 255, 0.06);
  --ds-fg: rgba(255, 255, 255, 0.92);
  --ds-fg-muted: rgba(255, 255, 255, 0.62);
  --ds-fg-dim: rgba(255, 255, 255, 0.38);
  --ds-accent: #AFA9EC;                 /* purpleLight */
  --ds-accent-soft: rgba(175, 169, 236, 0.10);
  --ds-accent-strong: rgba(175, 169, 236, 0.28);
  --ds-pill-border: rgba(175, 169, 236, 0.44);
  --ds-pill-bg: rgba(116, 97, 194, 0.18);
  --ds-pill-text: #AFA9EC;
}

/* System mode — follow OS when neither .light nor .dark is on body */
@media (prefers-color-scheme: dark) {
  body:not(.light):not(.dark) {
    --ds-bg: #0b0d12;
    --ds-bg-muted: #12141b;
    --ds-surface: #15181f;
    --ds-surface-hover: #1a1e27;
    --ds-border: rgba(255, 255, 255, 0.08);
    --ds-border-strong: rgba(255, 255, 255, 0.16);
    --ds-divider: rgba(255, 255, 255, 0.06);
    --ds-fg: rgba(255, 255, 255, 0.92);
    --ds-fg-muted: rgba(255, 255, 255, 0.62);
    --ds-fg-dim: rgba(255, 255, 255, 0.38);
    --ds-accent: #AFA9EC;
    --ds-accent-soft: rgba(175, 169, 236, 0.10);
    --ds-accent-strong: rgba(175, 169, 236, 0.28);
    --ds-pill-border: rgba(175, 169, 236, 0.44);
    --ds-pill-bg: rgba(116, 97, 194, 0.18);
    --ds-pill-text: #AFA9EC;
  }
}

/* --- Reset / base --------------------------------------------------------- */
* { box-sizing: border-box; }
html, body { margin: 0; padding: 0; }
body {
  background: var(--ds-bg);
  color: var(--ds-fg);
  font-family: var(--ds-system);
  font-size: 15px;
  line-height: 1.55;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
}
code, pre { font-family: var(--ds-mono); font-size: 0.88em; }
a { color: var(--ds-accent); text-decoration: none; }
a:hover { text-decoration: underline; }

/* --- Sticky header ------------------------------------------------------- */
.ds-header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 56px;
  padding: 0 32px;
  background: rgba(var(--ds-surface-rgb, 255, 255, 255), 0.88);
  backdrop-filter: saturate(180%) blur(12px);
  -webkit-backdrop-filter: saturate(180%) blur(12px);
  border-bottom: 1px solid var(--ds-divider);
}
body.dark .ds-header,
body:not(.light):not(.dark) .ds-header {
  background: rgba(11, 13, 18, 0.72);
}
body.light .ds-header {
  background: rgba(250, 251, 252, 0.82);
}
.ds-header-title {
  font-size: 15px;
  font-weight: 600;
  letter-spacing: -0.01em;
}
.ds-header-title .ds-mark { color: var(--ds-accent); }

/* --- Header toggles (Show swatches / Theme chrome) ----------------------- */
.ds-header-toggles {
  display: flex;
  align-items: center;
  gap: 16px;
  flex-wrap: wrap;
}
.ds-toggle-group {
  display: inline-flex;
  align-items: center;
  gap: 8px;
}
.ds-toggle-label {
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ds-fg-dim);
}
.ds-mode-toggle,
.ds-swatch-toggle {
  display: inline-flex;
  gap: 2px;
  padding: 2px;
  background: var(--ds-bg-muted);
  border: 1px solid var(--ds-border);
  border-radius: 999px;
}
.ds-mode-toggle button,
.ds-swatch-toggle button {
  appearance: none;
  background: transparent;
  border: 0;
  color: var(--ds-fg-muted);
  font: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 4px 12px;
  border-radius: 999px;
  cursor: pointer;
  transition: background 0.12s ease, color 0.12s ease;
}
.ds-mode-toggle button:hover,
.ds-swatch-toggle button:hover { color: var(--ds-fg); }
.ds-mode-toggle button.active,
.ds-swatch-toggle button.active {
  background: var(--ds-accent-soft);
  color: var(--ds-accent);
  box-shadow: inset 0 0 0 1px var(--ds-accent-strong);
}

/* --- Hamburger (CSS only; JS in VIB-483) --------------------------------- */
.ds-hamburger {
  display: none;
  appearance: none;
  background: transparent;
  border: 0;
  color: var(--ds-fg-muted);
  cursor: pointer;
  padding: 6px 8px;
  margin-right: 12px;
}
.ds-hamburger-icon, .ds-hamburger-icon::before, .ds-hamburger-icon::after {
  display: block;
  width: 18px;
  height: 2px;
  background: currentColor;
  border-radius: 1px;
  position: relative;
}
.ds-hamburger-icon::before, .ds-hamburger-icon::after { content: ""; position: absolute; left: 0; }
.ds-hamburger-icon::before { top: -6px; }
.ds-hamburger-icon::after { top: 6px; }

/* --- Layout grid: sidebar + main ---------------------------------------- */
.ds-layout {
  display: grid;
  grid-template-columns: 240px minmax(0, 1fr);
  max-width: 1360px;
  margin: 0 auto;
  padding: 0 32px;
}

.ds-sidebar {
  position: sticky;
  top: 56px;
  align-self: start;
  height: calc(100vh - 56px);
  overflow-y: auto;
  padding: 32px 24px 32px 0;
  border-right: 1px solid var(--ds-divider);
}
.ds-sidebar-section-label {
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--ds-fg-dim);
  margin: 0 0 8px 12px;
}
.ds-sidebar-nav { list-style: none; padding: 0; margin: 0 0 24px; }
.ds-sidebar-nav a {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  padding: 7px 12px;
  border-radius: 6px;
  font-size: 13px;
  color: var(--ds-fg-muted);
  transition: background 0.12s ease, color 0.12s ease;
}
.ds-sidebar-nav a:hover { background: var(--ds-surface-hover); color: var(--ds-fg); text-decoration: none; }
.ds-sidebar-nav a.active {
  background: var(--ds-accent-soft);
  color: var(--ds-accent);
  font-weight: 500;
}
.ds-sidebar-nav .ds-count {
  font-size: 11px;
  color: var(--ds-fg-dim);
  font-variant-numeric: tabular-nums;
}
.ds-sidebar-nav a.active .ds-count { color: var(--ds-accent); opacity: 0.75; }

.ds-sidebar-footer {
  padding: 16px 12px;
  border-top: 1px solid var(--ds-divider);
  font-size: 12px;
  color: var(--ds-fg-muted);
}
.ds-sidebar-footer a { color: var(--ds-fg-muted); }
.ds-sidebar-footer a:hover { color: var(--ds-accent); text-decoration: none; }

/* --- Main column -------------------------------------------------------- */
.ds-main {
  padding: 48px 32px 80px 48px;
  min-width: 0;
}

/* --- Hero --------------------------------------------------------------- */
.ds-hero { max-width: 720px; margin-bottom: 96px; }
.ds-hero h1 {
  font-size: 48px;
  line-height: 1.08;
  font-weight: 700;
  letter-spacing: -0.02em;
  margin: 0 0 20px;
  color: var(--ds-fg);
}
.ds-hero-intro {
  font-size: 18px;
  line-height: 1.6;
  color: var(--ds-fg-muted);
  margin: 0 0 24px;
}
.ds-hero-intro code {
  color: var(--ds-fg);
  background: var(--ds-bg-muted);
  padding: 2px 6px;
  border-radius: 4px;
  font-size: 14px;
}
.ds-hero-stats {
  display: flex;
  gap: 24px;
  padding-top: 24px;
  border-top: 1px solid var(--ds-divider);
  font-size: 12px;
  color: var(--ds-fg-dim);
}
.ds-hero-stat strong {
  display: block;
  color: var(--ds-fg);
  font-size: 22px;
  font-weight: 600;
  letter-spacing: -0.01em;
  margin-bottom: 2px;
}

/* --- Section containers ------------------------------------------------- */
.ds-section { margin: 0 0 96px; scroll-margin-top: 80px; }
.ds-section h2 {
  font-size: 28px;
  font-weight: 600;
  letter-spacing: -0.015em;
  margin: 0 0 12px;
  color: var(--ds-fg);
  display: flex;
  align-items: baseline;
  gap: 10px;
}
.ds-section h2 .ds-section-count {
  font-size: 14px;
  font-weight: 500;
  color: var(--ds-fg-dim);
  font-variant-numeric: tabular-nums;
}
.ds-section-intro {
  font-size: 16px;
  line-height: 1.6;
  color: var(--ds-fg-muted);
  max-width: 640px;
  margin: 0 0 40px;
}
.ds-section.collapsed > :not(h2) { display: none; }
.ds-section > h2 { cursor: pointer; user-select: none; }
.ds-section > h2::after {
  content: '▾';
  margin-left: auto;
  font-size: 14px;
  color: var(--ds-fg-dim);
  transition: transform 0.2s ease;
}
.ds-section.collapsed > h2::after { transform: rotate(-90deg); }

.ds-family {
  margin: 0 0 48px;
  padding: 0 0 32px;
  border-bottom: 1px solid var(--ds-divider);
}
.ds-family:last-child { border-bottom: 0; padding-bottom: 0; }
.ds-family h3 {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  color: var(--ds-fg-muted);
  margin: 0 0 18px;
}
.ds-family-meta { font-size: 12px; color: var(--ds-fg-dim); margin-left: 10px; font-weight: 400; text-transform: none; letter-spacing: 0; }

/* --- Grid layouts ------------------------------------------------------- */
.ds-grid {
  display: grid;
  gap: 20px;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
}
.ds-grid-narrow {
  display: grid;
  gap: 16px;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
}

/* --- Swatch card --------------------------------------------------------
   Fixed five-region layout. Page-level Both/Light/Dark toggle hides one
   half via body class; card dimensions never shift.
*/
.ds-swatch {
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 280px;
}

/* Title row — 44px */
.ds-swatch-title {
  height: 44px;
  flex: 0 0 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0 12px;
  font-family: var(--ds-mono);
  font-size: 12.5px;
  font-weight: 500;
  color: var(--ds-fg);
  text-align: center;
  border-bottom: 1px solid var(--ds-divider);
  word-break: break-all;
  line-height: 1.25;
}

/* Preview row — 64px */
.ds-swatch-preview {
  height: 64px;
  flex: 0 0 64px;
  display: flex;
}
.ds-swatch-half {
  flex: 1;
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.ds-swatch-half--dark { background: var(--ds-bar-dark); }
.ds-swatch-half--light { background: var(--ds-bar-light); }
.ds-swatch-fill { position: absolute; inset: 0; }

/* Text-pill preview (pillButtonText / pillButtonHoverText / pillButtonPrimaryText) */
.ds-text-pill {
  position: relative;
  z-index: 1;
  padding: 5px 14px;
  border-radius: 999px;
  border: 1.5px solid transparent;
  font-family: var(--ds-system);
  font-size: 11px;
  font-weight: 500;
  line-height: 1;
  white-space: nowrap;
}

/* Alias preview — full-width target pointer */
.ds-swatch-preview--alias { background: var(--ds-bg-muted); }
.ds-swatch-alias-target {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--ds-mono);
  font-size: 12.5px;
  color: var(--ds-fg-muted);
  letter-spacing: 0.01em;
}
.ds-swatch-alias-target code { color: var(--ds-fg); margin-left: 6px; }

/* Value row — 56px */
.ds-swatch-values {
  height: 56px;
  flex: 0 0 56px;
  display: flex;
  border-top: 1px solid var(--ds-divider);
  border-bottom: 1px solid var(--ds-divider);
}
.ds-swatch-value-half {
  flex: 1;
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  text-align: center;
  min-width: 0;
}
.ds-swatch-value-half--dark + .ds-swatch-value-half--light { border-left: 1px solid var(--ds-divider); }
.ds-swatch-values--single {
  height: 56px;
  flex: 0 0 56px;
  border-top: 1px solid var(--ds-divider);
  border-bottom: 1px solid var(--ds-divider);
  padding: 8px 12px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 3px;
  text-align: center;
}
.ds-swatch-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ds-fg-dim);
}
.ds-swatch-values code,
.ds-swatch-values--single code {
  font-family: var(--ds-mono);
  font-size: 10.5px;
  color: var(--ds-fg-muted);
  line-height: 1.3;
  word-break: break-all;
  overflow-wrap: anywhere;
}

/* Used-by footer — fills remaining */
.ds-swatch-usage {
  flex: 1;
  min-height: 0;
  padding: 10px 14px 12px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  overflow: hidden;
}
.ds-swatch-usage-label {
  font-size: 9px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--ds-fg-dim);
}
.ds-swatch-usage-list {
  flex: 1;
  font-family: var(--ds-mono);
  font-size: 10.5px;
  color: var(--ds-fg-muted);
  line-height: 1.45;
  overflow: hidden;
  word-break: break-word;
}
.ds-swatch-file + .ds-swatch-file::before { content: ', '; color: var(--ds-fg-dim); }
.ds-swatch-more {
  color: var(--ds-fg-dim);
}
.ds-swatch-more::before { content: ' '; }
.ds-swatch-usage-empty { color: var(--ds-fg-dim); font-style: italic; }

/* Page-level Both/Light/Dark swatch toggle */
body.swatch-mode-light .ds-swatch-half--dark,
body.swatch-mode-light .ds-swatch-value-half--dark { display: none; }
body.swatch-mode-dark .ds-swatch-half--light,
body.swatch-mode-dark .ds-swatch-value-half--light { display: none; }
/* When one half is hidden, the other's border-left becomes redundant */
body.swatch-mode-light .ds-swatch-value-half--light,
body.swatch-mode-dark .ds-swatch-value-half--dark { border-left: 0; }

/* --- Typography specimens ----------------------------------------------- */
.ds-font-list { display: flex; flex-direction: column; gap: 24px; }
.ds-font-sample {
  padding: 20px 22px;
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
}
.ds-font-specimen {
  color: var(--ds-fg);
  margin-bottom: 10px;
  line-height: 1.4;
}
.ds-font-meta {
  font-size: 11px;
  color: var(--ds-fg-dim);
  font-family: var(--ds-mono);
  padding-top: 10px;
  border-top: 1px solid var(--ds-divider);
}
.ds-font-meta code { color: var(--ds-fg-muted); }

/* --- Dimension cards ---------------------------------------------------- */
.ds-dim-card {
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
  padding: 18px 16px 14px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 120px;
}
.ds-dim-value {
  font-size: 34px;
  font-weight: 600;
  letter-spacing: -0.015em;
  color: var(--ds-fg);
  font-variant-numeric: tabular-nums;
  line-height: 1;
}
.ds-dim-unit {
  font-size: 13px;
  font-weight: 500;
  color: var(--ds-fg-dim);
  margin-left: 4px;
  letter-spacing: 0;
}
.ds-dim-name {
  font-family: var(--ds-mono);
  font-size: 11px;
  color: var(--ds-fg-muted);
  margin-top: 14px;
  word-break: break-all;
}
.ds-dim-desc { font-size: 11px; color: var(--ds-fg-dim); margin-top: 4px; line-height: 1.4; }

/* --- Footer ------------------------------------------------------------- */
.ds-footer {
  margin-top: 120px;
  padding: 32px 0 48px;
  border-top: 1px solid var(--ds-divider);
  font-size: 11px;
  color: var(--ds-fg-dim);
  display: flex;
  justify-content: space-between;
  flex-wrap: wrap;
  gap: 16px;
}
.ds-footer a { color: var(--ds-fg-muted); }
.ds-footer code { color: var(--ds-fg-muted); font-size: 10px; }

/* --- Component previews ------------------------------------------------- */
.ds-preview-row {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  padding: 20px 22px;
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
}
.ds-preview-row--dark { background: #1e1e1e; color: rgba(255,255,255,0.8); }
.ds-preview-stack {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding: 20px 22px;
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
}
/* Pill button family (default + hover via CSS :hover) */
.ds-pill-btn {
  appearance: none;
  font: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 6px 14px;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.15s ease;
  line-height: 1;
}
.ds-pill-btn--default {
  background: var(--ds-pill-bg);
  border: 1.5px solid var(--ds-pill-border);
  color: var(--ds-pill-text);
}
.ds-pill-btn--default:hover {
  background: rgba(83, 74, 183, 0.16);
  border-color: rgba(83, 74, 183, 0.65);
  color: var(--ds-accent);
}
body.dark .ds-pill-btn--default:hover,
body:not(.light):not(.dark) .ds-pill-btn--default:hover {
  background: rgba(116, 97, 194, 0.35);
  border-color: #C4B8F5;
  color: #C4B8F5;
}
.ds-pill-btn--copied {
  background: rgba(22, 163, 74, 0.12);
  border: 1.5px solid rgba(22, 163, 74, 0.5);
  color: rgba(22, 163, 74, 0.9);
}
.ds-pill-btn--primary {
  background: var(--ds-accent);
  color: white;
  border: 1.5px solid var(--ds-accent);
}
body.dark .ds-pill-btn--primary,
body:not(.light):not(.dark) .ds-pill-btn--primary {
  background: rgba(175, 169, 236, 0.16);
  color: #AFA9EC;
  border-color: rgba(175, 169, 236, 0.36);
}
.ds-pill-btn--primary:hover { filter: brightness(1.05); }

/* Secondary (ghost) pill */
.ds-secondary-btn {
  appearance: none;
  font: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 5px 12px;
  border-radius: 999px;
  background: transparent;
  border: 1.5px solid rgba(15, 23, 42, 0.15);
  color: rgba(15, 23, 42, 0.65);
  cursor: pointer;
  transition: all 0.15s ease;
}
body.dark .ds-secondary-btn,
body:not(.light):not(.dark) .ds-secondary-btn {
  border-color: rgba(255,255,255,0.20);
  color: rgba(255,255,255,0.60);
}
.ds-secondary-btn:hover {
  border-color: rgba(15, 23, 42, 0.25);
  color: rgba(15, 23, 42, 0.75);
  background: rgba(15, 23, 42, 0.04);
}
body.dark .ds-secondary-btn:hover,
body:not(.light):not(.dark) .ds-secondary-btn:hover {
  border-color: rgba(255,255,255,0.35);
  color: rgba(255,255,255,0.80);
  background: rgba(255,255,255,0.05);
}

/* Segmented control */
.ds-segmented {
  display: inline-flex;
  gap: 2px;
  padding: 2px;
  background: var(--ds-bg-muted);
  border: 1px solid var(--ds-border);
  border-radius: 999px;
}
.ds-segmented--primary { padding: 3px; border-radius: 12px; }
.ds-segmented-item {
  appearance: none;
  background: transparent;
  border: 0;
  color: var(--ds-fg-muted);
  font: inherit;
  font-size: 12px;
  font-weight: 500;
  padding: 4px 14px;
  border-radius: 999px;
  cursor: pointer;
  transition: all 0.12s ease;
}
.ds-segmented--primary .ds-segmented-item {
  font-size: 12px;
  font-weight: 600;
  padding: 5px 16px;
  border-radius: 9px;
}
.ds-segmented-item:hover { color: var(--ds-fg); }
.ds-segmented-item.active {
  background: var(--ds-accent-soft);
  color: var(--ds-accent);
  box-shadow: inset 0 0 0 1px var(--ds-accent-strong);
}

/* Note pill (red family) */
.ds-note-pill {
  display: inline-flex;
  align-items: center;
  font-size: 12px;
  padding: 4px 10px;
  border-radius: 13px;
  color: #7f1d1d;
  background: rgba(255, 248, 248, 0.82);
  border: 1px solid rgba(239, 68, 68, 0.18);
  transition: all 0.12s ease;
}
.ds-note-pill--hover,
.ds-note-pill:hover {
  background: rgba(255, 248, 248, 0.92);
  border-color: rgba(239, 68, 68, 0.45);
}
.ds-note-pill--selected {
  background: rgba(255, 248, 248, 0.96);
  border-color: rgba(239, 68, 68, 0.55);
}
.ds-note-pill--editing {
  background: rgba(255, 252, 252, 0.98);
  border-color: rgba(239, 68, 68, 0.55);
  box-shadow: 0 0 0 3px rgba(239, 68, 68, 0.10);
}

/* Status pill */
.ds-status-pill {
  display: inline-flex;
  padding: 4px 10px;
  border-radius: 12px;
  font-family: var(--ds-mono);
  font-size: 10px;
}
.ds-status-pill--dark { background: rgba(30,30,30,0.88); color: white; }
.ds-status-pill--light { background: rgba(255,255,255,0.85); color: rgba(0,0,0,0.70); border: 1px solid rgba(0,0,0,0.06); }

/* Tool button */
.ds-tool-btn {
  appearance: none;
  width: 30px;
  height: 30px;
  border-radius: 15px;
  border: 0;
  background: transparent;
  color: rgba(255,255,255,0.45);
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  transition: all 0.12s ease;
}
.ds-tool-btn:hover {
  background: rgba(255,255,255,0.08);
  color: rgba(255,255,255,0.80);
}
.ds-preview-row--dark .ds-mini-divider { background: rgba(255,255,255,0.12); }

/* Surface composed demos */
.ds-surface-demo {
  padding: 16px 18px;
  background: var(--ds-surface);
  border: 1px solid var(--ds-border);
  border-radius: 10px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}
.ds-surface-demo--toolbar { background: linear-gradient(135deg, #d7d9de, #a4a8b0); padding: 20px; }
.ds-surface-demo--screenshot { background: linear-gradient(135deg, #d7d9de, #6c707a); padding: 20px; }
.ds-surface-caption { font-size: 11px; color: var(--ds-fg-dim); font-family: var(--ds-mono); }
.ds-surface-caption code { color: var(--ds-fg-muted); }

.ds-mini-toolbar {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  padding: 5px 8px;
  background: rgba(30,30,30,0.92);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 20px;
  color: rgba(255,255,255,0.8);
}
.ds-mini-divider { width: 1px; height: 16px; background: rgba(255,255,255,0.12); margin: 0 4px; }
.ds-mini-field {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 6px 8px 6px 14px;
  background: var(--ds-bg-muted);
  border: 1px solid var(--ds-border);
  border-radius: 8px;
  font-family: var(--ds-mono);
  font-size: 12px;
}
.ds-mini-field code { color: var(--ds-fg); flex: 1; }
.ds-mini-frame {
  padding: 14px 16px;
  background: rgba(15, 23, 42, 0.02);
  border-radius: 18px;
}
.ds-mini-frame-title { font-size: 13px; font-weight: 500; margin-bottom: 4px; }
.ds-mini-frame-body { font-size: 12px; color: var(--ds-fg-muted); font-family: var(--ds-mono); }
.ds-mini-preview {
  padding: 12px 14px;
  background: #f8fafc;
  border-radius: 8px;
  font-family: var(--ds-mono);
  font-size: 12px;
}
body.dark .ds-mini-preview,
body:not(.light):not(.dark) .ds-mini-preview {
  background: #15161a;
  color: rgba(255,255,255,0.8);
}
.ds-mini-kbd-row { display: flex; gap: 4px; }
.ds-mini-kbd-row kbd {
  font-family: var(--ds-mono);
  font-size: 11px;
  padding: 4px 8px;
  background: rgba(0,0,0,0.03);
  border: 1px solid rgba(0,0,0,0.10);
  border-radius: 6px;
}
body.dark .ds-mini-kbd-row kbd,
body:not(.light):not(.dark) .ds-mini-kbd-row kbd {
  background: rgba(255,255,255,0.08);
  border-color: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.55);
}


/* --- Responsive --------------------------------------------------------- */
@media (max-width: 900px) {
  .ds-layout { grid-template-columns: 1fr; padding: 0 20px; }
  .ds-sidebar {
    position: fixed;
    top: 56px;
    left: 0;
    width: 260px;
    background: var(--ds-bg);
    border-right: 1px solid var(--ds-border);
    transform: translateX(-100%);
    transition: transform 0.24s ease;
    padding: 24px 20px 24px 24px;
    z-index: 90;
  }
  body.ds-sidebar-open .ds-sidebar { transform: translateX(0); }
  .ds-main { padding: 32px 0 64px; }
  .ds-hero h1 { font-size: 36px; }
  .ds-hamburger { display: inline-flex; }
}

/* Default active state for mode toggle (VIB-483 overrides with localStorage) */
</style>
</head>
<body>

<header class="ds-header">
  <div style="display: flex; align-items: center;">
    <button class="ds-hamburger" type="button" aria-label="Toggle sidebar">
      <span class="ds-hamburger-icon"></span>
    </button>
    <div class="ds-header-title"><span class="ds-mark">◆</span> Vibeliner Design System</div>
  </div>
  <div class="ds-header-toggles">
    <div class="ds-toggle-group">
      <span class="ds-toggle-label">Show</span>
      <div class="ds-swatch-toggle" role="group" aria-label="Swatch mode">
        <button data-swatch-mode="both" class="active" type="button">Both</button>
        <button data-swatch-mode="light" type="button">Light</button>
        <button data-swatch-mode="dark" type="button">Dark</button>
      </div>
    </div>
    <div class="ds-toggle-group">
      <span class="ds-toggle-label">Theme</span>
      <div class="ds-mode-toggle" role="group" aria-label="Color mode">
        <button data-mode="system" class="active" type="button">System</button>
        <button data-mode="light" type="button">Light</button>
        <button data-mode="dark" type="button">Dark</button>
      </div>
    </div>
  </div>
</header>

<div class="ds-layout">

  <aside class="ds-sidebar">
    <p class="ds-sidebar-section-label">Contents</p>
    <ul class="ds-sidebar-nav">
    {% for section in sections %}
      <li>
        <a href="#{{ section.id }}">
          <span>{{ section.title }}</span>
          <span class="ds-count">{{ tokens_by_section[section.id] | length }}</span>
        </a>
      </li>
    {% endfor %}
    </ul>
    <div class="ds-sidebar-footer">
      <a href="tour-design.html">Tour Design →</a>
    </div>
  </aside>

  <main class="ds-main">

    <div class="ds-hero">
      <h1>Every pixel, from code.</h1>
      <p class="ds-hero-intro">
        Vibeliner uses 4 universal component families and {{ token_count }} tokens
        to keep every surface consistent. This page is generated from
        <code>Vibeliner/Design/DesignTokens*.swift</code> — you cannot read a value
        here that disagrees with the code.
      </p>
      <div class="ds-hero-stats">
        <div class="ds-hero-stat">
          <strong>{{ token_count }}</strong>
          tokens in code
        </div>
        <div class="ds-hero-stat">
          <strong>{{ yaml_token_count }}</strong>
          in the catalog
        </div>
        <div class="ds-hero-stat">
          <strong>{{ sections | length }}</strong>
          sections
        </div>
      </div>
    </div>

    {# --- Live Components ----------------------------------------------- #}
    {% set components = tokens_by_section['components'] %}
    <section id="components" class="ds-section">
      <h2>Live Components <span class="ds-section-count">{{ components | length }}</span></h2>
      <p class="ds-section-intro">
        Interactive previews of every reusable component family.
        Hover an element to see its real state transitions — driven by CSS
        pseudo-classes, not hand-painted "hover variant" cards.
      </p>

      {% set ns = namespace(seen=[]) %}
      {% for name, token in components %}
        {% if token.family not in ns.seen %}
          {% set _ = ns.seen.append(token.family) %}
          {% set family = token.family %}
          {% set family_tokens = components | selectattr('1.family', 'equalto', family) | list %}
          <div class="ds-family" id="family-{{ family }}">
            <h3>{{ family }} <span class="ds-family-meta">· {{ family_tokens | length }} token{{ '' if family_tokens | length == 1 else 's' }}</span></h3>

            {% if family == 'pill-button' %}{{ c.pill_button_group() }}
            {% elif family == 'pill-button-primary' %}{{ c.pill_button_primary_group() }}
            {% elif family == 'segmented-control' %}{{ c.segmented_control_group() }}
            {% elif family == 'secondary-button' %}{{ c.secondary_button_group() }}
            {% elif family == 'note-pill' %}{{ c.note_pill_group() }}
            {% elif family == 'status-pill' %}{{ c.status_pill_group() }}
            {% elif family == 'add-image' %}
              <div class="ds-preview-row">{{ c.secondary_button('+ Add image') }}</div>
            {% elif family == 'copied-green' %}
              <div class="ds-preview-row">{{ c.pill_button('Copied ✓', 'copied') }}</div>
            {% elif family == 'editor-annotation' %}
              {{ c.note_pill_group() }}
            {% else %}
              <div class="ds-preview-row"><em style="color: var(--ds-fg-dim);">No preview for family {{ family }} yet.</em></div>
            {% endif %}

            <div class="ds-grid" style="margin-top: 20px;">
            {% for tname, tok in family_tokens %}
              {{ c.swatch(tname, tok, mode='dual') }}
            {% endfor %}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {# Also surface the tool-button family (its tokens live in surfaces/annotation) #}
      <div class="ds-family" id="family-tool-button">
        <h3>tool-button <span class="ds-family-meta">· 7 tools · one circular family</span></h3>
        {{ c.tool_button_group() }}
      </div>
    </section>

    {# --- Color Palette ------------------------------------------------- #}
    {% set colors = tokens_by_section['colors'] %}
    <section id="colors" class="ds-section">
      <h2>Color Palette <span class="ds-section-count">{{ colors | length }}</span></h2>
      <p class="ds-section-intro">
        Brand colors, annotation colors, role presets, and the ghost-preview
        accents. Each swatch is rendered over a dark surface, a light surface,
        and a screenshot gradient — the same three contexts Vibeliner's UI lives in.
      </p>
      <div class="ds-grid">
      {% for name, token in colors %}{{ c.swatch(name, token) }}{% endfor %}
      </div>
    </section>

    {# --- Typography ---------------------------------------------------- #}
    {% set typography = tokens_by_section['typography'] %}
    <section id="typography" class="ds-section">
      <h2>Typography <span class="ds-section-count">{{ typography | length }}</span></h2>
      <p class="ds-section-intro">
        System font at Vibeliner's sizes and weights. Each specimen is rendered
        at the exact size, weight, and family the token compiles to.
      </p>
      <div class="ds-font-list">
      {% for name, token in typography %}{{ c.font_sample(name, token) }}{% endfor %}
      </div>
    </section>

    {# --- Dimensions ---------------------------------------------------- #}
    {% set dimensions = tokens_by_section['dimensions'] %}
    <section id="dimensions" class="ds-section">
      <h2>Dimensions <span class="ds-section-count">{{ dimensions | length }}</span></h2>
      <p class="ds-section-intro">
        Measurements that define Vibeliner's spatial rhythm — badge sizes, toolbar
        heights, corner radii, gaps. Every number in the app resolves to one of these.
      </p>
      <div class="ds-grid-narrow">
      {% for name, token in dimensions %}{{ c.dimension_card(name, token) }}{% endfor %}
      </div>
    </section>

    {# --- Surfaces ------------------------------------------------------ #}
    {% set surfaces = tokens_by_section['surfaces'] %}
    <section id="surfaces" class="ds-section">
      <h2>Surfaces <span class="ds-section-count">{{ surfaces | length }}</span></h2>
      <p class="ds-section-intro">
        Appearance-aware background and border tokens — toolbar, status pill,
        settings field, setup window. Where a token anchors a recognizable composed
        surface, we show the composition. Everything else gets a dual-bar swatch.
      </p>
      <div class="ds-grid">
      {% for name, token in surfaces %}{{ c.surface_sample(name, token) }}{% endfor %}
      </div>
    </section>

    <footer class="ds-footer">
      <div>
        {{ token_count }} tokens generated from <code>{{ source_files | join(', ') }}</code>
      </div>
      <div>
        <a href="https://github.com/janaj2g-hub/vibeliner">GitHub</a>
        &nbsp;·&nbsp;
        <a href="tour-design.html">Tour Design</a>
        &nbsp;·&nbsp;
        <code>python3 scripts/design_system_codegen.py</code>
      </div>
    </footer>

  </main>
</div>

<script>
/* Vibeliner design-system — three vanilla IIFEs. Each is independent: if one
   fails silently (no sidebar, private browsing, old Safari), the others run. */

(function modeToggle() {
  var KEY = 'vibeliner-design-system-mode';
  var toggle = document.querySelector('.ds-mode-toggle');
  if (!toggle) return;
  function apply(mode) {
    document.body.classList.remove('light', 'dark');
    if (mode === 'light' || mode === 'dark') document.body.classList.add(mode);
    toggle.querySelectorAll('[data-mode]').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.mode === mode);
    });
  }
  function getSaved() { try { return localStorage.getItem(KEY) || 'system'; } catch (e) { return 'system'; } }
  function save(mode) { try { localStorage.setItem(KEY, mode); } catch (e) {} }
  toggle.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-mode]');
    if (!btn) return;
    save(btn.dataset.mode);
    apply(btn.dataset.mode);
  });
  var mq = window.matchMedia('(prefers-color-scheme: dark)');
  var onChange = function () { if (getSaved() === 'system') apply('system'); };
  if (mq.addEventListener) mq.addEventListener('change', onChange);
  else if (mq.addListener) mq.addListener(onChange);
  apply(getSaved());
})();

(function sidebar() {
  var nav = document.querySelector('.ds-sidebar-nav');
  if (!nav) return;
  nav.addEventListener('click', function (e) {
    var link = e.target.closest('a[href^="#"]');
    if (!link) return;
    e.preventDefault();
    var target = document.querySelector(link.getAttribute('href'));
    if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
    document.body.classList.remove('ds-sidebar-open');
  });
  var links = nav.querySelectorAll('a[href^="#"]');
  var sections = document.querySelectorAll('section[id]');
  if ('IntersectionObserver' in window && sections.length) {
    var observer = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        var id = entry.target.id;
        links.forEach(function (l) {
          l.classList.toggle('active', l.getAttribute('href') === '#' + id);
        });
      });
    }, { rootMargin: '-40% 0px -40% 0px' });
    sections.forEach(function (s) { observer.observe(s); });
  }
  var hamburger = document.querySelector('.ds-hamburger');
  if (hamburger) {
    hamburger.addEventListener('click', function () {
      document.body.classList.toggle('ds-sidebar-open');
    });
  }
})();

(function swatchMode() {
  var KEY = 'vibeliner-design-system-swatch-mode';
  var toggle = document.querySelector('.ds-swatch-toggle');
  if (!toggle) return;
  function apply(mode) {
    document.body.classList.remove('swatch-mode-light', 'swatch-mode-dark');
    if (mode === 'light') document.body.classList.add('swatch-mode-light');
    else if (mode === 'dark') document.body.classList.add('swatch-mode-dark');
    toggle.querySelectorAll('[data-swatch-mode]').forEach(function (btn) {
      btn.classList.toggle('active', btn.dataset.swatchMode === mode);
    });
  }
  function getSaved() { try { return localStorage.getItem(KEY) || 'both'; } catch (e) { return 'both'; } }
  function save(mode) { try { localStorage.setItem(KEY, mode); } catch (e) {} }
  toggle.addEventListener('click', function (e) {
    var btn = e.target.closest('[data-swatch-mode]');
    if (!btn) return;
    save(btn.dataset.swatchMode);
    apply(btn.dataset.swatchMode);
  });
  apply(getSaved());
})();

(function usageOverflow() {
  /* Walk every .ds-swatch-usage-list; if its content overflows, progressively
     hide trailing <span.ds-swatch-file> until it fits, then append "+N more". */
  function trim(list) {
    if (list.classList.contains('ds-swatch-usage-empty')) return;
    // Remove any previous "+N more" so re-runs idempotent.
    var prev = list.querySelector('.ds-swatch-more');
    if (prev) prev.remove();
    var files = Array.prototype.slice.call(list.querySelectorAll('.ds-swatch-file'));
    files.forEach(function (f) { f.style.display = ''; });
    if (list.scrollHeight <= list.clientHeight + 1) return;
    var hidden = 0;
    for (var i = files.length - 1; i >= 0; i--) {
      files[i].style.display = 'none';
      hidden++;
      if (list.scrollHeight <= list.clientHeight + 1) break;
    }
    if (hidden === 0) return;
    var more = document.createElement('span');
    more.className = 'ds-swatch-more';
    more.textContent = '+' + hidden + ' more';
    list.appendChild(more);
    // If "+N more" pushed us over, hide one more file.
    while (list.scrollHeight > list.clientHeight + 1 && hidden < files.length) {
      for (var j = files.length - 1; j >= 0; j--) {
        if (files[j].style.display !== 'none') { files[j].style.display = 'none'; hidden++; break; }
      }
      more.textContent = '+' + hidden + ' more';
    }
  }
  var lists = document.querySelectorAll('.ds-swatch-usage-list');
  function run() { lists.forEach(trim); }
  run();
  // Re-run on window resize (card widths change → wrap changes).
  var t;
  window.addEventListener('resize', function () {
    clearTimeout(t);
    t = setTimeout(run, 120);
  });
})();

(function sectionCollapse() {
  var KEY = 'vibeliner-design-system-collapsed';
  function getSet() {
    try { return new Set(JSON.parse(localStorage.getItem(KEY) || '[]')); } catch (e) { return new Set(); }
  }
  function saveSet(set) { try { localStorage.setItem(KEY, JSON.stringify(Array.from(set))); } catch (e) {} }
  var collapsed = getSet();
  document.querySelectorAll('section[id] > h2').forEach(function (h2) {
    var section = h2.parentElement;
    if (collapsed.has(section.id)) section.classList.add('collapsed');
    h2.addEventListener('click', function () {
      section.classList.toggle('collapsed');
      if (section.classList.contains('collapsed')) collapsed.add(section.id);
      else collapsed.delete(section.id);
      saveSet(collapsed);
    });
  });
})();
</script>

</body>
</html>
